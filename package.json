{
  "name": "o-bit",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:push": "pnpm --filter @repo/database db:push",
    "db:migrate": "pnpm --filter @repo/database migrate:dev",
    "db:generate": "pnpm --filter @repo/database generate",
    "db:seed": "pnpm --filter @repo/database seed"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
